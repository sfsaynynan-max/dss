<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>لوحة تحكم المنصة</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg:       #0a0c10;
    --surface:  #111318;
    --border:   #1e2128;
    --border2:  #2a2d36;
    --text:     #e8eaf0;
    --muted:    #6b7280;
    --accent:   #4f8ef7;
    --accent2:  #7c3aed;
    --green:    #22c55e;
    --yellow:   #f59e0b;
    --red:      #ef4444;
    --radius:   10px;
    --font:     'IBM Plex Sans Arabic', sans-serif;
    --mono:     'JetBrains Mono', monospace;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 15px; }
  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── Login ──────────────────────────────────── */
  #login-screen {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(ellipse 80% 50% at 50% -10%, rgba(79,142,247,.15) 0%, transparent 70%),
      var(--bg);
  }
  .login-box {
    width: 380px;
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 16px;
    padding: 40px;
    box-shadow: 0 32px 80px rgba(0,0,0,.5);
  }
  .login-logo {
    text-align: center;
    margin-bottom: 32px;
  }
  .login-logo .icon {
    width: 56px; height: 56px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    margin-bottom: 12px;
  }
  .login-logo h1 { font-size: 1.3rem; font-weight: 600; }
  .login-logo p { color: var(--muted); font-size: .85rem; margin-top: 4px; }

  /* ── Layout ─────────────────────────────────── */
  #app { display: none; min-height: 100vh; }
  #app.visible { display: flex; }

  .sidebar {
    width: 220px;
    min-height: 100vh;
    background: var(--surface);
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    position: fixed;
    right: 0; top: 0; bottom: 0;
    z-index: 100;
  }
  .sidebar-logo {
    padding: 24px 20px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 10px;
  }
  .sidebar-logo .icon {
    width: 34px; height: 34px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
  }
  .sidebar-logo span { font-weight: 600; font-size: .95rem; }
  .nav { padding: 12px 0; flex: 1; }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 20px;
    color: var(--muted);
    cursor: pointer;
    border-right: 3px solid transparent;
    transition: all .15s;
    font-size: .9rem;
    user-select: none;
  }
  .nav-item:hover { color: var(--text); background: rgba(255,255,255,.03); }
  .nav-item.active {
    color: var(--accent);
    border-right-color: var(--accent);
    background: rgba(79,142,247,.07);
  }
  .nav-item .icon { font-size: 1rem; width: 20px; text-align: center; }
  .sidebar-footer {
    padding: 16px 20px;
    border-top: 1px solid var(--border);
  }

  .main {
    margin-right: 220px;
    flex: 1;
    padding: 32px;
    min-height: 100vh;
  }
  .page { display: none; }
  .page.active { display: block; }

  .page-header {
    margin-bottom: 28px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .page-header h2 { font-size: 1.4rem; font-weight: 600; }
  .page-header p { color: var(--muted); font-size: .85rem; margin-top: 3px; }

  /* ── Components ─────────────────────────────── */
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 16px;
    border-radius: var(--radius);
    border: none; cursor: pointer;
    font-family: var(--font); font-size: .875rem; font-weight: 500;
    transition: all .15s;
    white-space: nowrap;
  }
  .btn-primary {
    background: var(--accent);
    color: #fff;
  }
  .btn-primary:hover { background: #3d7de0; }
  .btn-ghost {
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--border2);
  }
  .btn-ghost:hover { color: var(--text); border-color: var(--border2); background: rgba(255,255,255,.04); }
  .btn-danger { background: rgba(239,68,68,.15); color: var(--red); border: 1px solid rgba(239,68,68,.25); }
  .btn-danger:hover { background: rgba(239,68,68,.25); }
  .btn-sm { padding: 5px 10px; font-size: .8rem; }
  .btn:disabled { opacity: .45; cursor: not-allowed; }

  label { display: block; font-size: .82rem; color: var(--muted); margin-bottom: 6px; }
  input[type=text], input[type=password], input[type=url],
  input[type=datetime-local], textarea, select {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    color: var(--text);
    font-family: var(--font);
    font-size: .9rem;
    padding: 9px 13px;
    outline: none;
    transition: border-color .15s;
  }
  input:focus, textarea:focus, select:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(79,142,247,.12);
  }
  textarea { resize: vertical; min-height: 80px; }
  select option { background: var(--surface); }

  .form-group { margin-bottom: 18px; }
  .form-row { display: grid; gap: 16px; }
  .form-row.col2 { grid-template-columns: 1fr 1fr; }
  .form-row.col3 { grid-template-columns: 1fr 1fr 1fr; }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  .card-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
  }
  .card-header h3 { font-size: .95rem; font-weight: 600; }
  .card-body { padding: 20px; }

  /* ── Status badges ───────────────────────────── */
  .badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 9px;
    border-radius: 99px;
    font-size: .75rem; font-weight: 500;
  }
  .badge-pending  { background: rgba(245,158,11,.12); color: var(--yellow); }
  .badge-processing { background: rgba(79,142,247,.12); color: var(--accent); }
  .badge-done    { background: rgba(34,197,94,.12); color: var(--green); }
  .badge-failed  { background: rgba(239,68,68,.12); color: var(--red); }
  .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
  .badge-processing .badge-dot { animation: pulse 1.2s ease-in-out infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.35} }

  /* ── Courses grid ─────────────────────────────── */
  .courses-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }
  .course-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color .15s;
  }
  .course-card:hover { border-color: var(--border2); }
  .course-thumb {
    width: 100%; height: 150px;
    object-fit: cover;
    background: var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 2rem; color: var(--muted);
  }
  .course-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .course-info { padding: 14px; }
  .course-info h4 { font-size: .9rem; font-weight: 600; margin-bottom: 4px; }
  .course-info p { font-size: .78rem; color: var(--muted); margin-bottom: 10px; line-height: 1.5; }
  .course-meta {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 10px;
  }
  .course-meta span { font-size: .75rem; color: var(--muted); }
  .course-actions { display: flex; gap: 6px; }

  /* ── Lectures table ───────────────────────────── */
  table { width: 100%; border-collapse: collapse; }
  th, td {
    text-align: right;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    font-size: .85rem;
  }
  th { color: var(--muted); font-weight: 500; font-size: .78rem; text-transform: uppercase; letter-spacing: .04em; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(255,255,255,.015); }

  /* ── Lecture inputs ───────────────────────────── */
  .lecture-inputs { display: flex; flex-direction: column; gap: 12px; }
  .lecture-row {
    background: var(--bg);
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    padding: 14px;
    position: relative;
  }
  .lecture-row-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 12px;
  }
  .lecture-num {
    font-size: .75rem; font-weight: 600;
    color: var(--accent);
    background: rgba(79,142,247,.1);
    padding: 2px 8px; border-radius: 99px;
  }

  /* ── Categories ───────────────────────────────── */
  .cats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }
  .cat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px;
    display: flex; align-items: center; justify-content: space-between;
    transition: border-color .15s;
  }
  .cat-card:hover { border-color: var(--border2); }
  .cat-left { display: flex; align-items: center; gap: 10px; }
  .cat-icon { font-size: 1.5rem; }
  .cat-name { font-size: .9rem; font-weight: 500; }
  .cat-name-en { font-size: .75rem; color: var(--muted); }

  /* ── Toast ────────────────────────────────────── */
  #toast-container {
    position: fixed; bottom: 24px; left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    display: flex; flex-direction: column; gap: 8px;
    align-items: center;
  }
  .toast {
    padding: 10px 20px;
    border-radius: 99px;
    font-size: .85rem;
    font-weight: 500;
    animation: toastIn .25s ease;
    white-space: nowrap;
  }
  .toast-success { background: rgba(34,197,94,.15); color: var(--green); border: 1px solid rgba(34,197,94,.25); }
  .toast-error   { background: rgba(239,68,68,.15);  color: var(--red);   border: 1px solid rgba(239,68,68,.25); }
  .toast-info    { background: rgba(79,142,247,.15); color: var(--accent); border: 1px solid rgba(79,142,247,.25); }
  @keyframes toastIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

  /* ── Modal ────────────────────────────────────── */
  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,.6);
    backdrop-filter: blur(4px);
    z-index: 200;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity .2s;
  }
  .modal-overlay.open { opacity: 1; pointer-events: all; }
  .modal {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 16px;
    width: 680px;
    max-width: 95vw;
    max-height: 90vh;
    overflow-y: auto;
    transform: translateY(16px);
    transition: transform .2s;
  }
  .modal-overlay.open .modal { transform: translateY(0); }
  .modal-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    position: sticky; top: 0; background: var(--surface); z-index: 1;
  }
  .modal-header h3 { font-size: 1rem; font-weight: 600; }
  .modal-body { padding: 24px; }
  .modal-footer {
    padding: 16px 24px;
    border-top: 1px solid var(--border);
    display: flex; justify-content: flex-end; gap: 8px;
    position: sticky; bottom: 0; background: var(--surface);
  }

  /* ── Progress bar ─────────────────────────────── */
  .progress-bar {
    height: 3px; background: var(--border);
    border-radius: 99px; overflow: hidden; margin-top: 8px;
  }
  .progress-fill {
    height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent2));
    border-radius: 99px; transition: width .4s;
  }

  /* ── Empty state ──────────────────────────────── */
  .empty {
    text-align: center; padding: 60px 20px; color: var(--muted);
  }
  .empty .icon { font-size: 3rem; margin-bottom: 12px; opacity: .5; }
  .empty p { font-size: .9rem; }

  /* ── Stat cards ───────────────────────────────── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-bottom: 28px;
  }
  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px;
  }
  .stat-label { font-size: .75rem; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; }
  .stat-value { font-size: 1.8rem; font-weight: 700; margin-top: 4px; font-variant-numeric: tabular-nums; }
  .stat-sub { font-size: .75rem; color: var(--muted); margin-top: 3px; }

  /* ── URL input with thumbnail preview ─────────── */
  .yt-preview {
    display: flex; align-items: center; gap: 10px;
    margin-top: 8px;
    padding: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: none;
  }
  .yt-preview.show { display: flex; }
  .yt-preview img { width: 80px; height: 45px; border-radius: 4px; object-fit: cover; }
  .yt-preview span { font-size: .8rem; color: var(--muted); font-family: var(--mono); }

  .spinner {
    width: 16px; height: 16px;
    border: 2px solid rgba(255,255,255,.2);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin .7s linear infinite;
    display: inline-block;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 99px; }
</style>
</head>
<body>

<!-- ───────────── LOGIN ───────────── -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">
      <div class="icon">🎓</div>
      <h1>لوحة التحكم</h1>
      <p>منصة الدورات التعليمية المترجمة</p>
    </div>
    <div class="form-group">
      <label>اسم المستخدم</label>
      <input type="text" id="login-user" placeholder="admin" autocomplete="username"/>
    </div>
    <div class="form-group">
      <label>كلمة المرور</label>
      <input type="password" id="login-pass" placeholder="••••••••" autocomplete="current-password"/>
    </div>
    <button class="btn btn-primary" style="width:100%;justify-content:center;padding:11px;" onclick="doLogin()">
      تسجيل الدخول
    </button>
    <p id="login-err" style="color:var(--red);font-size:.8rem;text-align:center;margin-top:12px;display:none;"></p>
  </div>
</div>

<!-- ───────────── APP ───────────── -->
<div id="app">
  <!-- Sidebar -->
  <nav class="sidebar">
    <div class="sidebar-logo">
      <div class="icon">🎓</div>
      <span>المنصة</span>
    </div>
    <div class="nav">
      <div class="nav-item active" onclick="goTo('dashboard')">
        <span class="icon">📊</span> لوحة التحكم
      </div>
      <div class="nav-item" onclick="goTo('courses')">
        <span class="icon">📚</span> الدورات
      </div>
      <div class="nav-item" onclick="goTo('categories')">
        <span class="icon">🗂️</span> المجالات
      </div>
      <div class="nav-item" onclick="goTo('processing')">
        <span class="icon">⚙️</span> قيد المعالجة
      </div>
    </div>
    <div class="sidebar-footer">
      <button class="btn btn-ghost btn-sm" style="width:100%;justify-content:center;" onclick="logout()">
        تسجيل الخروج
      </button>
    </div>
  </nav>

  <!-- Main -->
  <main class="main">

    <!-- Dashboard -->
    <div class="page active" id="page-dashboard">
      <div class="page-header">
        <div>
          <h2>لوحة التحكم</h2>
          <p>نظرة عامة على المنصة</p>
        </div>
      </div>
      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-label">الدورات</div>
          <div class="stat-value" id="stat-courses">—</div>
          <div class="stat-sub">منشورة</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">المحاضرات</div>
          <div class="stat-value" id="stat-lectures">—</div>
          <div class="stat-sub">إجمالي</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">قيد المعالجة</div>
          <div class="stat-value" id="stat-processing">—</div>
          <div class="stat-sub">تحتاج وقتاً</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">المجالات</div>
          <div class="stat-value" id="stat-cats">—</div>
          <div class="stat-sub">نشطة</div>
        </div>
      </div>
      <div class="card">
        <div class="card-header">
          <h3>آخر الدورات المضافة</h3>
          <button class="btn btn-primary btn-sm" onclick="goTo('courses');setTimeout(openAddCourse,100)">+ إضافة دورة</button>
        </div>
        <div class="card-body" style="padding:0">
          <table>
            <thead><tr>
              <th>الدورة</th><th>المجال</th><th>المحاضرات</th><th>الحالة</th><th></th>
            </tr></thead>
            <tbody id="dash-courses-tbody">
              <tr><td colspan="5" style="text-align:center;color:var(--muted);padding:30px">جاري التحميل...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Courses -->
    <div class="page" id="page-courses">
      <div class="page-header">
        <div>
          <h2>الدورات</h2>
          <p>إدارة جميع الدورات التعليمية</p>
        </div>
        <button class="btn btn-primary" onclick="openAddCourse()">+ إضافة دورة</button>
      </div>
      <div id="courses-container">
        <div class="empty"><div class="icon">📭</div><p>لا توجد دورات بعد</p></div>
      </div>
    </div>

    <!-- Categories -->
    <div class="page" id="page-categories">
      <div class="page-header">
        <div>
          <h2>المجالات</h2>
          <p>إدارة مجالات الدورات</p>
        </div>
        <button class="btn btn-primary" onclick="openAddCat()">+ إضافة مجال</button>
      </div>
      <div class="cats-grid" id="cats-grid">
        <div style="color:var(--muted);font-size:.85rem">جاري التحميل...</div>
      </div>
    </div>

    <!-- Processing -->
    <div class="page" id="page-processing">
      <div class="page-header">
        <div>
          <h2>قيد المعالجة</h2>
          <p>حالة معالجة المحاضرات</p>
        </div>
        <button class="btn btn-ghost btn-sm" onclick="loadProcessing()">↻ تحديث</button>
      </div>
      <div class="card">
        <div class="card-body" style="padding:0">
          <table>
            <thead><tr>
              <th>المحاضرة</th><th>الدورة</th><th>الحالة</th><th>التفاصيل</th>
            </tr></thead>
            <tbody id="processing-tbody">
              <tr><td colspan="4" style="text-align:center;color:var(--muted);padding:30px">جاري التحميل...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </main>
</div>

<!-- ───────────── ADD COURSE MODAL ───────────── -->
<div class="modal-overlay" id="modal-course">
  <div class="modal">
    <div class="modal-header">
      <h3>إضافة دورة جديدة</h3>
      <button class="btn btn-ghost btn-sm" onclick="closeModal('modal-course')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-row col2">
        <div class="form-group">
          <label>اسم الدورة (إنجليزي)</label>
          <input type="text" id="c-title" placeholder="Introduction to AI"/>
        </div>
        <div class="form-group">
          <label>المجال</label>
          <select id="c-cat">
            <option value="">اختر المجال...</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>وصف الدورة (اختياري)</label>
        <textarea id="c-desc" placeholder="نبذة عن محتوى الدورة..."></textarea>
      </div>
      <div class="form-group">
        <label>تاريخ النشر (اختياري)</label>
        <input type="datetime-local" id="c-date"/>
      </div>

      <hr style="border-color:var(--border);margin:20px 0"/>

      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
        <div>
          <div style="font-size:.9rem;font-weight:600">المحاضرات</div>
          <div style="font-size:.75rem;color:var(--muted);margin-top:2px">ستُعالج تلقائياً بعد الإرسال</div>
        </div>
        <button class="btn btn-ghost btn-sm" onclick="addLectureRow()">+ إضافة محاضرة</button>
      </div>

      <div class="lecture-inputs" id="lecture-inputs">
        <!-- Lecture rows injected here -->
      </div>
    </div>
    <div class="modal-footer">
      <div id="submit-progress" style="display:none;margin-left:auto;align-items:center;gap:10px;font-size:.82rem;color:var(--muted)">
        <span class="spinner"></span>
        <span id="submit-progress-text">جاري الإرسال...</span>
      </div>
      <button class="btn btn-ghost" onclick="closeModal('modal-course')">إلغاء</button>
      <button class="btn btn-primary" id="submit-btn" onclick="submitCourse()">
        🚀 إرسال ومعالجة
      </button>
    </div>
  </div>
</div>

<!-- ───────────── ADD CATEGORY MODAL ───────────── -->
<div class="modal-overlay" id="modal-cat">
  <div class="modal" style="width:400px">
    <div class="modal-header">
      <h3>إضافة مجال جديد</h3>
      <button class="btn btn-ghost btn-sm" onclick="closeModal('modal-cat')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>الاسم بالعربية</label>
        <input type="text" id="cat-ar" placeholder="الذكاء الاصطناعي"/>
      </div>
      <div class="form-group">
        <label>الاسم بالإنجليزية</label>
        <input type="text" id="cat-en" placeholder="Artificial Intelligence"/>
      </div>
      <div class="form-group">
        <label>الأيقونة (Emoji)</label>
        <input type="text" id="cat-icon" placeholder="🤖" style="font-size:1.2rem"/>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-cat')">إلغاء</button>
      <button class="btn btn-primary" onclick="submitCat()">إضافة</button>
    </div>
  </div>
</div>

<!-- Toast container -->
<div id="toast-container"></div>

<script>
// ─── Config ─────────────────────────────────────
const API = localStorage.getItem('api_url') || '';

// Auto-ask for API URL if not set
window.addEventListener('load', () => {
  const saved = localStorage.getItem('api_url');
  if (!saved) {
    const url = prompt('أدخل رابط الـ Backend (Railway URL):', 'https://your-app.railway.app');
    if (url) localStorage.setItem('api_url', url.replace(/\/$/, ''));
    location.reload();
  }
});

function getAPI() { return localStorage.getItem('api_url') || ''; }
function getToken() { return localStorage.getItem('token') || ''; }

async function req(method, path, body = null) {
  const res = await fetch(getAPI() + path, {
    method,
    headers: {
      'Content-Type': 'application/json',
      ...(getToken() ? { Authorization: 'Bearer ' + getToken() } : {})
    },
    ...(body ? { body: JSON.stringify(body) } : {})
  });
  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    throw new Error(err.detail || res.statusText);
  }
  return res.json();
}

// ─── Auth ────────────────────────────────────────
async function doLogin() {
  const user = document.getElementById('login-user').value.trim();
  const pass = document.getElementById('login-pass').value;
  const err  = document.getElementById('login-err');
  try {
    const data = await req('POST', '/api/admin/login', { username: user, password: pass });
    localStorage.setItem('token', data.access_token);
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('app').classList.add('visible');
    loadAll();
  } catch(e) {
    err.textContent = 'بيانات غير صحيحة';
    err.style.display = 'block';
  }
}
document.getElementById('login-pass').addEventListener('keydown', e => {
  if (e.key === 'Enter') doLogin();
});

function logout() {
  localStorage.removeItem('token');
  location.reload();
}

// Check existing token
if (getToken()) {
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app').classList.add('visible');
  loadAll();
}

// ─── Navigation ──────────────────────────────────
const pages = ['dashboard','courses','categories','processing'];
function goTo(name) {
  pages.forEach(p => {
    document.getElementById('page-'+p).classList.toggle('active', p === name);
    document.querySelectorAll('.nav-item').forEach((el, i) => {
      el.classList.toggle('active', pages[i] === name);
    });
  });
  if (name === 'dashboard')   loadDashboard();
  if (name === 'courses')     loadCourses();
  if (name === 'categories')  loadCategories();
  if (name === 'processing')  loadProcessing();
}

// ─── Load All ────────────────────────────────────
let categories = [];
let courses = [];

async function loadAll() {
  await Promise.all([loadCategories(), loadCourses()]);
  loadDashboard();
}

async function loadCategories() {
  try {
    categories = await req('GET', '/api/admin/categories');
    renderCategories();
    // populate select
    const sel = document.getElementById('c-cat');
    sel.innerHTML = '<option value="">اختر المجال...</option>';
    categories.forEach(c => {
      sel.innerHTML += `<option value="${c.id}">${c.icon || ''} ${c.name_ar}</option>`;
    });
  } catch(e) { toast('خطأ في تحميل المجالات', 'error'); }
}

async function loadCourses() {
  try {
    courses = await req('GET', '/api/admin/courses');
    renderCourses();
  } catch(e) { toast('خطأ في تحميل الدورات', 'error'); }
}

function loadDashboard() {
  document.getElementById('stat-courses').textContent = courses.length;
  const totalLectures = courses.reduce((s,c) => s + (c.lectures_count||0), 0);
  document.getElementById('stat-lectures').textContent = totalLectures;
  document.getElementById('stat-cats').textContent = categories.filter(c=>c.is_active).length;
  // processing count requires more detail; show placeholder
  document.getElementById('stat-processing').textContent = '...';

  const tbody = document.getElementById('dash-courses-tbody');
  if (!courses.length) {
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:30px">لا توجد دورات</td></tr>';
    return;
  }
  tbody.innerHTML = courses.slice(0,8).map(c => {
    const cat = categories.find(x => x.id === c.category_id);
    return `<tr>
      <td><div style="font-weight:500">${c.title_ar || c.title}</div></td>
      <td>${cat ? cat.icon+' '+cat.name_ar : '—'}</td>
      <td>${c.lectures_count} محاضرة</td>
      <td><span class="badge badge-done"><span class="badge-dot"></span>منشورة</span></td>
      <td><button class="btn btn-ghost btn-sm" onclick="viewStatus(${c.id})">الحالة</button></td>
    </tr>`;
  }).join('');
}

// ─── Courses ─────────────────────────────────────
function renderCourses() {
  const el = document.getElementById('courses-container');
  if (!courses.length) {
    el.innerHTML = '<div class="empty"><div class="icon">📭</div><p>لا توجد دورات بعد، أضف أول دورة!</p></div>';
    return;
  }
  el.innerHTML = '<div class="courses-grid">' + courses.map(c => {
    const cat = categories.find(x => x.id === c.category_id);
    const thumb = c.thumbnail_url || '';
    return `<div class="course-card">
      <div class="course-thumb">
        ${thumb ? `<img src="${thumb}" onerror="this.parentElement.textContent='🎓'"/>` : '🎓'}
      </div>
      <div class="course-info">
        <h4>${c.title_ar || c.title}</h4>
        <p>${c.description_ar || c.description || '—'}</p>
        <div class="course-meta">
          <span>${cat ? cat.icon+' '+cat.name_ar : '—'}</span>
          <span>${c.lectures_count} محاضرة</span>
        </div>
        <div class="course-actions">
          <button class="btn btn-ghost btn-sm" onclick="viewStatus(${c.id})">⚙️ الحالة</button>
          <button class="btn btn-danger btn-sm" onclick="deleteCourse(${c.id})">حذف</button>
        </div>
      </div>
    </div>`;
  }).join('') + '</div>';
}

async function deleteCourse(id) {
  if (!confirm('هل أنت متأكد من حذف هذه الدورة؟')) return;
  try {
    await req('DELETE', `/api/admin/courses/${id}`);
    toast('تم حذف الدورة', 'success');
    await loadCourses();
  } catch(e) { toast('فشل الحذف', 'error'); }
}

// ─── Categories ──────────────────────────────────
function renderCategories() {
  const grid = document.getElementById('cats-grid');
  if (!categories.length) {
    grid.innerHTML = '<div style="color:var(--muted);font-size:.85rem">لا توجد مجالات</div>';
    return;
  }
  grid.innerHTML = categories.filter(c=>c.is_active).map(c => `
    <div class="cat-card">
      <div class="cat-left">
        <div class="cat-icon">${c.icon || '📁'}</div>
        <div>
          <div class="cat-name">${c.name_ar}</div>
          <div class="cat-name-en">${c.name}</div>
        </div>
      </div>
      <button class="btn btn-danger btn-sm" onclick="deleteCat(${c.id})">حذف</button>
    </div>
  `).join('');
}

function openAddCat() { openModal('modal-cat'); }
async function submitCat() {
  const ar = document.getElementById('cat-ar').value.trim();
  const en = document.getElementById('cat-en').value.trim();
  const icon = document.getElementById('cat-icon').value.trim();
  if (!ar || !en) { toast('أدخل الاسمين', 'error'); return; }
  try {
    await req('POST', '/api/admin/categories', { name: en, name_ar: ar, icon });
    toast('تم إضافة المجال ✓', 'success');
    closeModal('modal-cat');
    document.getElementById('cat-ar').value = '';
    document.getElementById('cat-en').value = '';
    document.getElementById('cat-icon').value = '';
    await loadCategories();
  } catch(e) { toast('فشل الإضافة: '+e.message, 'error'); }
}

async function deleteCat(id) {
  if (!confirm('حذف هذا المجال؟')) return;
  try {
    await req('DELETE', `/api/admin/categories/${id}`);
    toast('تم الحذف', 'success');
    await loadCategories();
  } catch(e) { toast('فشل الحذف', 'error'); }
}

// ─── Processing ───────────────────────────────────
async function loadProcessing() {
  const tbody = document.getElementById('processing-tbody');
  tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;padding:24px"><span class="spinner"></span></td></tr>';
  try {
    // Fetch status for all courses
    const rows = [];
    let processingCount = 0;
    for (const course of courses) {
      const statuses = await req('GET', `/api/admin/courses/${course.id}/status`);
      for (const lec of statuses) {
        if (lec.status !== 'done') processingCount++;
        rows.push({ ...lec, course_title: course.title_ar || course.title });
      }
    }
    document.getElementById('stat-processing').textContent = processingCount;

    if (!rows.length) {
      tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--muted);padding:30px">لا توجد محاضرات</td></tr>';
      return;
    }

    tbody.innerHTML = rows.map(r => `
      <tr>
        <td>${r.title}</td>
        <td style="color:var(--muted)">${r.course_title}</td>
        <td>${statusBadge(r.status)}</td>
        <td style="font-size:.78rem;color:var(--red)">${r.error || ''}</td>
      </tr>
    `).join('');
  } catch(e) { toast('خطأ في تحميل الحالة', 'error'); }
}

async function viewStatus(courseId) {
  goTo('processing');
  await loadProcessing();
}

function statusBadge(s) {
  const map = {
    pending: 'badge-pending',
    processing: 'badge-processing',
    done: 'badge-done',
    failed: 'badge-failed'
  };
  const ar = { pending: 'في الانتظار', processing: 'جاري المعالجة', done: 'مكتمل', failed: 'فشل' };
  return `<span class="badge ${map[s]||'badge-pending'}"><span class="badge-dot"></span>${ar[s]||s}</span>`;
}

// ─── Add Course ───────────────────────────────────
let lectureCount = 0;

function openAddCourse() {
  lectureCount = 0;
  document.getElementById('lecture-inputs').innerHTML = '';
  document.getElementById('c-title').value = '';
  document.getElementById('c-desc').value = '';
  document.getElementById('c-date').value = '';
  addLectureRow();
  openModal('modal-course');
}

function addLectureRow() {
  lectureCount++;
  const num = lectureCount;
  const container = document.getElementById('lecture-inputs');
  const div = document.createElement('div');
  div.className = 'lecture-row';
  div.id = `lrow-${num}`;
  div.innerHTML = `
    <div class="lecture-row-header">
      <span class="lecture-num">محاضرة ${num}</span>
      ${num > 1 ? `<button class="btn btn-danger btn-sm" onclick="removeLecture(${num})">حذف</button>` : ''}
    </div>
    <div class="form-row col2">
      <div class="form-group" style="margin:0">
        <label>رابط يوتيوب</label>
        <input type="url" id="lurl-${num}" placeholder="https://youtube.com/watch?v=..."
          oninput="previewYT(${num})"/>
        <div class="yt-preview" id="lprev-${num}">
          <img id="lprev-img-${num}" src=""/>
          <span id="lprev-id-${num}"></span>
        </div>
      </div>
      <div class="form-group" style="margin:0">
        <label>عنوان المحاضرة</label>
        <input type="text" id="ltitle-${num}" placeholder="Lecture ${num}: Introduction"/>
      </div>
    </div>
  `;
  container.appendChild(div);
}

function removeLecture(num) {
  document.getElementById('lrow-'+num)?.remove();
}

function extractYTId(url) {
  const m = url.match(/(?:v=|youtu\.be\/|embed\/)([a-zA-Z0-9_-]{11})/);
  return m ? m[1] : null;
}

function previewYT(num) {
  const url = document.getElementById('lurl-'+num).value;
  const id = extractYTId(url);
  const prev = document.getElementById('lprev-'+num);
  if (id) {
    document.getElementById('lprev-img-'+num).src = `https://img.youtube.com/vi/${id}/mqdefault.jpg`;
    document.getElementById('lprev-id-'+num).textContent = id;
    prev.classList.add('show');
  } else {
    prev.classList.remove('show');
  }
}

async function submitCourse() {
  const title = document.getElementById('c-title').value.trim();
  const catId = parseInt(document.getElementById('c-cat').value);
  const desc  = document.getElementById('c-desc').value.trim();
  const date  = document.getElementById('c-date').value;

  if (!title) { toast('أدخل اسم الدورة', 'error'); return; }
  if (!catId)  { toast('اختر المجال', 'error'); return; }

  // Collect lectures
  const lectures = [];
  document.querySelectorAll('.lecture-row').forEach(row => {
    const num = row.id.replace('lrow-','');
    const url   = document.getElementById('lurl-'+num)?.value.trim();
    const lTitle = document.getElementById('ltitle-'+num)?.value.trim();
    if (url && lTitle) lectures.push({ youtube_url: url, title: lTitle });
  });

  if (!lectures.length) { toast('أضف محاضرة واحدة على الأقل', 'error'); return; }

  const btn = document.getElementById('submit-btn');
  const prog = document.getElementById('submit-progress');
  btn.disabled = true;
  prog.style.display = 'flex';
  document.getElementById('submit-progress-text').textContent = 'جاري الترجمة والإرسال...';

  try {
    const body = { title, description: desc || null, category_id: catId, lectures };
    if (date) body.published_at = new Date(date).toISOString();

    const result = await req('POST', '/api/admin/courses', body);
    toast(`تم إنشاء الدورة! ${result.lectures_queued} محاضرة قيد المعالجة 🚀`, 'success');
    closeModal('modal-course');
    await loadCourses();
    goTo('processing');
  } catch(e) {
    toast('خطأ: ' + e.message, 'error');
  } finally {
    btn.disabled = false;
    prog.style.display = 'none';
  }
}

// ─── Modal helpers ───────────────────────────────
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(el => {
  el.addEventListener('click', e => { if (e.target === el) closeModal(el.id); });
});

// ─── Toast ───────────────────────────────────────
function toast(msg, type = 'info') {
  const el = document.createElement('div');
  el.className = `toast toast-${type}`;
  el.textContent = msg;
  document.getElementById('toast-container').appendChild(el);
  setTimeout(() => el.remove(), 3500);
}
</script>
</body>
</html>
